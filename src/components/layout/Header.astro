---
import HeaderNavigation from './HeaderNavigation.astro';
import HeaderNavigationToggle from './HeaderNavigationToggle.astro';
import ThemeToggle from './ThemeToggle.astro';
---

<header
	class="flex flex-row flex-wrap items-center justify-between gap-6 py-4 sm:py-8 lg:py-16 [&_a]:underline-offset-6 [&_a]:hover:underline"
>
	<p class="font-sans text-xl font-medium">
		<a href="/">Thomas Weichselbaumer</a>
	</p>
	<HeaderNavigationToggle />
	<div
		id="nav-menu"
		class="flex flex-col items-center gap-12 max-sm:mt-16 max-sm:hidden max-sm:w-full sm:flex-row sm:gap-6 lg:gap-10"
	>
		<HeaderNavigation />
		<ThemeToggle />
	</div>
</header>
